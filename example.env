# The address to access the app from public (for swagger-ui)
PUBLIC_SERVER=http://localhost:9090

# The port to access the app from local
HTTP_PORT=9090

# Directory for storing data that is publicly downloadable
PUBLIC_DATA_DIR=./data/public

# Directory for storing private data used by internal services
PRIVATE_DATA_DIR=./data/private

# Directory for storing uploaded images
IMAGE_DIR=./images

# uid and gid of the user who can write to the image directory
UID=1001
GID=1001

KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=

MYSQL_ROOT_PASSWORD=
MYSQL_USER=
MYSQL_PASSWORD=

# In ibb realm of the keycloak instance, there must be a client with the name ibb-client. This is the secret of that client
KEYCLOAK_CLIENT_SECRET=

# This should be a at least 48 characters random string
NUXT_OIDC_SESSION_SECRET=

# This needs to be a random cryptographic AES key in base64
NUXT_OIDC_TOKEN_KEY=

# This should be a at least 48 characters random string
NUXT_OIDC_AUTH_SESSION_SECRET=

# Project name (prefix for containers)
COMPOSE_PROJECT_NAME=ibb
